{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/((?!api/|public/).*)", "destination": "/public/$1" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' *.tableau.com *.online.tableau.com"
        }
      ]
    }
  ]
}
