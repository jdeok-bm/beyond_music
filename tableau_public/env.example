# ──────────────────────────────────────────────
# Tableau Portal — 환경변수 설정 예시
# Vercel 대시보드: Settings → Environment Variables 에 각 항목을 등록하세요.
# 이 파일(.env.example)은 git에 커밋해도 안전합니다.
# 실제 값이 들어간 .env 파일은 절대 커밋하지 마세요.
# ──────────────────────────────────────────────

# Tableau Cloud 서버 URL (끝에 슬래시 없이)
# 예) https://prod-apnortheast-a.online.tableau.com
TABLEAU_SERVER_URL=https://YOUR_REGION.online.tableau.com

# Site 이름 (Tableau Cloud 관리자 콘솔 URL에서 확인)
# Default Site 이면 빈 문자열("")로 설정
# 예) https://prod-apnortheast-a.online.tableau.com/#/site/mycompany → mycompany
TABLEAU_SITE_NAME=your-site-name

# Connected Apps 에서 발급한 Client ID
# Tableau Cloud → 설정 → Connected Apps → 앱 이름 클릭 → Client ID
TABLEAU_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Connected Apps Secret ID (Value가 아닌 ID)
# Connected Apps → Secret 탭 → Secret ID 열
TABLEAU_SECRET_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Connected Apps Secret Value (발급 시 한 번만 표시됨)
TABLEAU_SECRET_VALUE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 임베딩에 사용할 Tableau 계정 이메일 (본인 계정)
TABLEAU_USERNAME=you@yourcompany.com

# 포털이 배포될 URL (CORS 보안용, 와일드카드 없이 정확히 입력)
# 예) https://my-portal.vercel.app
TOKEN_AUDIENCE=https://your-portal.vercel.app
